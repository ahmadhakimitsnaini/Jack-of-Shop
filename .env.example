# ============================================================
# Jack Of Shopee — Environment Configuration Template
# SALIN file ini menjadi .env dan isi dengan nilai asli.
# JANGAN commit file .env ke dalam git!
# ============================================================

# --- Database (Supabase Transaction Pooler) ---
# Port 6543 = Transaction Pooler (WAJIB untuk aplikasi async/multiprocess)
# Port 5432 = Direct Connection (hanya untuk Alembic migration jika diperlukan)
DATABASE_URL=postgresql+asyncpg://[USER]:[PASSWORD]@[HOST]:6543/[DB_NAME]

# --- Redis (Celery Broker & Result Backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Aplikasi ---
APP_ENV=development
APP_DEBUG=True
APP_SECRET_KEY=your-secret-key-here
